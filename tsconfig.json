{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitAny": false,
    "strict": false,
    "esModuleInterop": true,
    "target": "esnext",
    "outDir": "dist",
    "rootDir": "./src",
    "sourceMap": true,
    "baseUrl": ".",
    "moduleResolution": "node",
    "removeComments": true,
    "resolveJsonModule": true,
    "typeRoots": ["@types", "./node_modules/@types"],
    "paths": {
      "*": ["node_modules/@types/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
